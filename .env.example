# Notion integration token — create one at https://www.notion.so/my-integrations
# (New integration -> Internal -> copy the token). Then SHARE each page/database
# with the integration (page ... -> Connections -> add your integration), or it
# won't be able to see them.
NOTION_API_KEY=

# Alias also accepted if you prefer:
# NOTION_TOKEN=

# Optional: pin the Notion API version (default: 2022-06-28)
# NOTION_VERSION=2022-06-28

# Optional: override where the per-call audit log is written
# (default: ~/.claude/notion-mcp/audit.log.jsonl)
# NOTION_MCP_AUDIT_LOG=
